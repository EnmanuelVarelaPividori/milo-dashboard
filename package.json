{
  "name": "milo-dashboard",
  "version": "1.0.0",
  "description": "Milo dashboard bootstrap",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:dev": "tsx src/scripts/migrate.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "db:up": "sh -c 'if command -v docker-compose >/dev/null 2>&1; then docker-compose up -d postgres; else docker compose up -d postgres; fi'",
    "db:down": "sh -c 'if command -v docker-compose >/dev/null 2>&1; then docker-compose stop postgres; else docker compose stop postgres; fi'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EnmanuelVarelaPividori/milo-dashboard.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/EnmanuelVarelaPividori/milo-dashboard/issues"
  },
  "homepage": "https://github.com/EnmanuelVarelaPividori/milo-dashboard#readme",
  "private": true,
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}

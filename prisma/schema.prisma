generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique
  name       String
  schedule   String
  enabled    Boolean  @default(true)
  lastRunAt  DateTime? @map("last_run_at") @db.Timestamptz(6)
  nextRunAt  DateTime? @map("next_run_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  jobRuns    JobRun[]

  @@map("jobs")
}

model JobRun {
  id         String     @id @default(uuid()) @db.Uuid
  jobId      String     @map("job_id") @db.Uuid
  status     String
  startedAt  DateTime   @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt DateTime?  @map("finished_at") @db.Timestamptz(6)
  summary    String?
  error      String?
  data       Json       @default("{}")
  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  ticketRuns TicketRun[]

  @@map("job_runs")
}

model TicketRun {
  id             String    @id @default(uuid()) @db.Uuid
  jobRunId       String?   @map("job_run_id") @db.Uuid
  jiraKey        String    @map("jira_key")
  jiraSummary    String?   @map("jira_summary")
  jiraStatus     String?   @map("jira_status")
  dispatchStatus String    @map("dispatch_status")
  score          Int?
  branchName     String?   @map("branch_name")
  prUrl          String?   @map("pr_url")
  note           String?
  testSummary    String?   @map("test_summary")
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz(6)
  data           Json      @default("{}")
  jobRun         JobRun?   @relation(fields: [jobRunId], references: [id], onDelete: SetNull)

  @@index([jiraKey, startedAt])
  @@map("ticket_runs")
}
